  let len_i32 (self_: t_Vec_i32_Global) (return (x: UInt64.t)) = any
    [ return (result: UInt64.t) -> {[@stop_split] [@expl:len ensures] UInt64.t'int result
      = Seq.length (view_Vec_i32_Global self_)}
      (! return {result}) ]
  
  predicate is_sorted (elems: Seq.seq Int32.t) (start: int) (end': int) =
    forall i: int, j: int. start <= i /\ i < j /\ j < end'
      -> Int32.to_int (Seq.get elems i) <= Int32.to_int (Seq.get elems j)
  
  predicate in_bounds_usize [@inline:trivial] (self: UInt64.t) (seq: Seq.seq Int32.t) =
    UInt64.t'int self < Seq.length seq
  
  meta "rewrite_def" predicate in_bounds_usize
  
  predicate has_value_usize [@inline:trivial] (self: UInt64.t) (seq: Seq.seq Int32.t) (out: Int32.t) =
    Seq.get seq (UInt64.t'int self) = out
  
  meta "rewrite_def" predicate has_value_usize
  
  let index_Vec_i32_Global (self_: t_Vec_i32_Global) (ix: UInt64.t) (return (x: Int32.t)) =
  {[@stop_split] [@expl:index requires] in_bounds_usize ix (view_Vec_i32_Global self_)}
    any
    [ return (result: Int32.t) ->
    {[@stop_split] [@expl:index ensures] has_value_usize ix (view_Vec_i32_Global self_) result}
      (! return {result}) ]
  
  meta "compute_max_steps" 1000000
  
  meta "select_lsinst" "all"
  
  let is_sorted'0 (data: t_Vec_i32_Global) (return (x: bool)) = (! bb0
    [ bb0 = s0
      [ s0 = len_i32 {data} (fun (_x: UInt64.t) -> [ &_6 <- _x ] s1)
      | s1 = [ &_5 <- UInt64.lt _6 (2: UInt64.t) ] s2
      | s2 = any [ br0 -> {_5 = false} (! bb3) | br1 -> {_5} (! bb2) ] ]
    | bb2 = s0 [ s0 = [ &_ret <- true ] s1 | s1 = return {_ret} ]
    | bb3 = s0 [ s0 = [ &i <- (1: UInt64.t) ] s1 | s1 = bb4 ]
    | bb4 = bb4
      [ bb4 = {[@expl:loop invariant] is_sorted (view_Vec_i32_Global data) 0 (UInt64.t'int i) /\ UInt64.t'int i > 0}
        (! s0)
        [ s0 = len_i32 {data} (fun (_x: UInt64.t) -> [ &_18 <- _x ] s1)
        | s1 = [ &_16 <- UInt64.lt i _18 ] s2
        | s2 = any [ br0 -> {_16 = false} (! bb12) | br1 -> {_16} (! bb7) ] ]
        [ bb7 = s0
          [ s0 = index_Vec_i32_Global {data} {i} (fun (_x: Int32.t) -> [ &_23 <- _x ] s1)
          | s1 = UInt64.sub {i} {(1: UInt64.t)} (fun (_x: UInt64.t) -> [ &_29 <- _x ] s2)
          | s2 = index_Vec_i32_Global {data} {_29} (fun (_x: Int32.t) -> [ &_27 <- _x ] s3)
          | s3 = [ &_21 <- Int32.lt _23 _27 ] s4
          | s4 = any [ br0 -> {_21 = false} (! bb11) | br1 -> {_21} (! bb10) ] ]
        | bb11 = s0 [ s0 = UInt64.add {i} {(1: UInt64.t)} (fun (_x: UInt64.t) -> [ &i <- _x ] s1) | s1 = bb4 ] ] ]
    | bb10 = s0 [ s0 = [ &_ret <- false ] s1 | s1 = return {_ret} ]
    | bb12 = s0 [ s0 = [ &_ret <- true ] s1 | s1 = return {_ret} ] ]
    [ & _ret: bool = Any.any_l ()
    | & data: t_Vec_i32_Global = data
    | & _5: bool = Any.any_l ()
    | & _6: UInt64.t = Any.any_l ()
    | & i: UInt64.t = Any.any_l ()
    | & _16: bool = Any.any_l ()
    | & _18: UInt64.t = Any.any_l ()
    | & _21: bool = Any.any_l ()
    | & _23: Int32.t = Any.any_l ()
    | & _27: Int32.t = Any.any_l ()
    | & _29: UInt64.t = Any.any_l () ])
    [ return (result: bool) -> {[@stop_split] [@expl:is_sorted ensures] result
      = is_sorted (view_Vec_i32_Global data) 0 (Seq.length (view_Vec_i32_Global data))}
      (! return {result}) ]
end
