module M_gnome_sort
  use creusot.int.UInt64
  use creusot.prelude.MutBorrow
  use seq.Seq
  use creusot.int.Int32
  use seq.Permut
  use creusot.slice.Slice64
  use creusot.prelude.Any
  use int.Int
  
  type t_Vec_i32_Global
  
  constant const_MAX: UInt64.t = (18446744073709551615: UInt64.t)
  
  function view_Vec_i32_Global (self: t_Vec_i32_Global) : Seq.seq Int32.t
  
  axiom view_Vec_i32_Global_spec:
    forall self: t_Vec_i32_Global [view_Vec_i32_Global self]. Seq.length (view_Vec_i32_Global self)
      <= UInt64.t'int const_MAX
  
  let len_i32 (self_: t_Vec_i32_Global) (return (x: UInt64.t)) = any
    [ return (result: UInt64.t) -> {[@stop_split] [@expl:len ensures] UInt64.t'int result
      = Seq.length (view_Vec_i32_Global self_)}
      (! return {result}) ]
  
  predicate permutation_of_i32 (self: Seq.seq Int32.t) (other: Seq.seq Int32.t) =
    Permut.permut self other 0 (Seq.length self)
  
  predicate is_sorted (elems: Seq.seq Int32.t) (start: int) (end': int) =
    forall i: int, j: int. start <= i /\ i < j /\ j < end'
      -> Int32.to_int (Seq.get elems i) <= Int32.to_int (Seq.get elems j)
  
  predicate in_bounds_usize [@inline:trivial] (self: UInt64.t) (seq: Seq.seq Int32.t) =
    UInt64.t'int self < Seq.length seq
  
  meta "rewrite_def" predicate in_bounds_usize
  
  predicate has_value_usize [@inline:trivial] (self: UInt64.t) (seq: Seq.seq Int32.t) (out: Int32.t) =
    Seq.get seq (UInt64.t'int self) = out
  
  meta "rewrite_def" predicate has_value_usize
  
  let index_Vec_i32_Global (self_: t_Vec_i32_Global) (ix: UInt64.t) (return (x: Int32.t)) =
  {[@stop_split] [@expl:index requires] in_bounds_usize ix (view_Vec_i32_Global self_)}
    any
    [ return (result: Int32.t) ->
    {[@stop_split] [@expl:index ensures] has_value_usize ix (view_Vec_i32_Global self_) result}
      (! return {result}) ]
  
  let deref_mut_Vec_i32_Global (self_: MutBorrow.t t_Vec_i32_Global) (return (x: MutBorrow.t (Slice64.slice Int32.t))) =
  any
    [ return (result: MutBorrow.t (Slice64.slice Int32.t)) ->
    {[@stop_split] [@expl:deref_mut_Vec_i32_Global ensures] ([@stop_split] [@expl:deref_mut ensures #0] Slice64.view result.current
        = view_Vec_i32_Global self_.current)
      /\ ([@stop_split] [@expl:deref_mut ensures #1] Seq.length (view_Vec_i32_Global self_.final)
        = Seq.length (view_Vec_i32_Global self_.current))
      /\ ([@stop_split] [@expl:deref_mut ensures #2] Slice64.view result.final = view_Vec_i32_Global self_.final)}
      (! return {result}) ]
  
  let swap_i32 (self_: MutBorrow.t (Slice64.slice Int32.t)) (i: UInt64.t) (j: UInt64.t) (return (x: ())) =
  {[@stop_split] [@expl:swap_i32 requires] ([@stop_split] [@expl:swap requires #0] UInt64.t'int i
      < Seq.length (Slice64.view self_.current))
    /\ ([@stop_split] [@expl:swap requires #1] UInt64.t'int j < Seq.length (Slice64.view self_.current))}
    any
    [ return (result: ()) ->
    {[@stop_split] [@expl:swap ensures] Permut.exchange (Slice64.view self_.final) (Slice64.view self_.current) (UInt64.t'int i) (UInt64.t'int j)}
      (! return {result}) ]
  
  predicate resolve_refmut_slice_i32 [@inline:trivial] (_1: MutBorrow.t (Slice64.slice Int32.t)) = _1.final = _1.current
  
  meta "rewrite_def" predicate resolve_refmut_slice_i32
  
  predicate resolve_refmut_Vec_i32_Global [@inline:trivial] (_1: MutBorrow.t t_Vec_i32_Global) = _1.final = _1.current
  
  meta "rewrite_def" predicate resolve_refmut_Vec_i32_Global
  
  meta "compute_max_steps" 1000000
  
  meta "select_lsinst" "all"
  
  let gnome_sort (v: MutBorrow.t t_Vec_i32_Global) (return (x: ())) = (! bb0
    [ bb0 = s0 [ s0 = [ &old_v <- v ] s1 | s1 = [ &i <- (0: UInt64.t) ] s2 | s2 = [ &_old <- v.final ] s3 | s3 = bb2 ]
    | bb2 = bb2
      [ bb2 = {[@expl:inferred invariant: unchanged value] _old = v.final}
        {[@expl:loop invariant #0] is_sorted (view_Vec_i32_Global v.current) 0 (UInt64.t'int i)}
        {[@expl:loop invariant #1] permutation_of_i32 (view_Vec_i32_Global v.current) (view_Vec_i32_Global old_v.current)}
        (! s0)
        [ s0 = len_i32 {v.current} (fun (_x: UInt64.t) -> [ &_20 <- _x ] s1)
        | s1 = [ &_18 <- UInt64.lt i _20 ] s2
        | s2 = any [ br0 -> {_18 = false} (! bb16) | br1 -> {_18} (! bb5) ] ]
        [ bb5 = s0
          [ s0 = [ &_22 <- i = (0: UInt64.t) ] s1 | s1 = any [ br0 -> {_22 = false} (! bb7) | br1 -> {_22} (! bb11) ] ]
        | bb7 = s0
          [ s0 = UInt64.sub {i} {(1: UInt64.t)} (fun (_x: UInt64.t) -> [ &_28 <- _x ] s1)
          | s1 = index_Vec_i32_Global {v.current} {_28} (fun (_x: Int32.t) -> [ &_26 <- _x ] s2)
          | s2 = index_Vec_i32_Global {v.current} {i} (fun (_x: Int32.t) -> [ &_31 <- _x ] s3)
          | s3 = [ &_24 <- Int32.le _26 _31 ] s4
          | s4 = any [ br0 -> {_24 = false} (! bb12) | br1 -> {_24} (! bb11) ] ]
        | bb11 = s0 [ s0 = UInt64.add {i} {(1: UInt64.t)} (fun (_x: UInt64.t) -> [ &i <- _x ] s1) | s1 = bb2 ]
        | bb12 = s0
          [ s0 = MutBorrow.borrow_mut <t_Vec_i32_Global> {v.current}
              (fun (_bor: MutBorrow.t t_Vec_i32_Global) ->
                [ &_37 <- _bor ] [ &v <- { v with current = _bor.final } ] s1)
          | s1 = deref_mut_Vec_i32_Global {_37} (fun (_x: MutBorrow.t (Slice64.slice Int32.t)) -> [ &_36 <- _x ] s2)
          | s2 = UInt64.sub {i} {(1: UInt64.t)} (fun (_x: UInt64.t) -> [ &_38 <- _x ] s3)
          | s3 = MutBorrow.borrow_final <Slice64.slice Int32.t> {_36.current} {MutBorrow.get_id _36}
              (fun (_bor: MutBorrow.t (Slice64.slice Int32.t)) ->
                [ &_35 <- _bor ] [ &_36 <- { _36 with current = _bor.final } ] s4)
          | s4 = swap_i32 {_35} {_38} {i} (fun (_x: ()) -> [ &_34 <- _x ] s5)
          | s5 = -{resolve_refmut_slice_i32 _36}- s6
          | s6 = UInt64.sub {i} {(1: UInt64.t)} (fun (_x: UInt64.t) -> [ &i <- _x ] s7)
          | s7 = bb2 ] ] ]
    | bb16 = s0 [ s0 = -{resolve_refmut_Vec_i32_Global v}- s1 | s1 = return {_ret} ] ]
    [ & _ret: () = Any.any_l ()
    | & v: MutBorrow.t t_Vec_i32_Global = v
    | & old_v: MutBorrow.t t_Vec_i32_Global = Any.any_l ()
    | & i: UInt64.t = Any.any_l ()
    | & _18: bool = Any.any_l ()
    | & _20: UInt64.t = Any.any_l ()
    | & _22: bool = Any.any_l ()
    | & _24: bool = Any.any_l ()
    | & _26: Int32.t = Any.any_l ()
    | & _28: UInt64.t = Any.any_l ()
    | & _31: Int32.t = Any.any_l ()
    | & _34: () = Any.any_l ()
    | & _35: MutBorrow.t (Slice64.slice Int32.t) = Any.any_l ()
    | & _36: MutBorrow.t (Slice64.slice Int32.t) = Any.any_l ()
    | & _37: MutBorrow.t t_Vec_i32_Global = Any.any_l ()
    | & _38: UInt64.t = Any.any_l ()
    | & _old: t_Vec_i32_Global = Any.any_l () ])
    [ return (result: ()) ->
    {[@stop_split] [@expl:gnome_sort ensures] ([@stop_split] [@expl:gnome_sort ensures #0] is_sorted (view_Vec_i32_Global v.final) 0 (Seq.length (view_Vec_i32_Global v.final)))
      /\ ([@stop_split] [@expl:gnome_sort ensures #1] permutation_of_i32 (view_Vec_i32_Global v.final) (view_Vec_i32_Global v.current))}
      (! return {result}) ]
end
module M_is_sorted
  use creusot.int.UInt64
  use seq.Seq
  use creusot.int.Int32
  use creusot.prelude.Any
  use int.Int
  
  type t_Vec_i32_Global
  
  constant const_MAX: UInt64.t = (18446744073709551615: UInt64.t)
  
  function view_Vec_i32_Global (self: t_Vec_i32_Global) : Seq.seq Int32.t
  
  axiom view_Vec_i32_Global_spec:
