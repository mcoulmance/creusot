module M_impl_T_for_i32__greater_or_eq (* <i32 as T> *)
  use creusot.int.Int32
  use creusot.prelude.Any
  use int.Int
  
  predicate ge_log_Int [@inline:trivial] (self: int) (other: int) = other <= self
  
  meta "rewrite_def" predicate ge_log_Int
  
  function deep_model_i32 [@inline:trivial] (self: Int32.t) : int = Int32.to_int self
  
  meta "rewrite_def" function deep_model_i32
  
  function deep_model_ref_i32 [@inline:trivial] (self: Int32.t) : int = deep_model_i32 self
  
  meta "rewrite_def" function deep_model_ref_i32
  
  let ge_i32 (self_: Int32.t) (other: Int32.t) (return (x: bool)) = any
    [ return (result: bool) -> {[@stop_split] [@expl:ge ensures] result
      = ge_log_Int (deep_model_ref_i32 self_) (deep_model_ref_i32 other)}
      (! return {result}) ]
  
  predicate greater_or_eq_i32 (x: Int32.t) (y: Int32.t) = ge_log_Int (deep_model_i32 x) (deep_model_i32 y)
  
  meta "compute_max_steps" 1000000
  
  meta "select_lsinst" "all"
  
  let greater_or_eq_i32'0 (lhs: Int32.t) (rhs: Int32.t) (return (x: bool)) = (! bb0
    [ bb0 = s0 [ s0 = ge_i32 {lhs} {rhs} (fun (_x: bool) -> [ &_ret <- _x ] s1) | s1 = return {_ret} ] ]
    [ & _ret: bool = Any.any_l () | & lhs: Int32.t = lhs | & rhs: Int32.t = rhs ])
    [ return (result: bool) -> {[@stop_split] [@expl:greater_or_eq ensures] result = greater_or_eq_i32 lhs rhs}
      (! return {result}) ]
end
